---
import '../styles/global.css';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>John Chisowa</title>
    <meta name="description" content="Angular developer building modern, scalable web applications." />
  </head>
  <body class="bg-gray-1 text-gray-11">
    <main class="mx-auto max-w-2xl px-6 py-16 md:py-24">
      <section class="mb-20">
        <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-12">
          John Chisowa
        </h1>
        <p class="mt-4 text-lg text-gray-11 max-w-lg leading-relaxed">
          Angular developer passionate about building modern, scalable, and maintainable web applications.
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-gray-10">
          <span>Lusaka, Zambia</span>
          <span class="inline-flex items-center rounded-full bg-tomato-3 px-3 py-1 text-xs font-medium text-tomato-11">
            Available for work
          </span>
        </div>
      </section>

      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-12 mb-10">Blog</h2>
        <div class="space-y-10">
          {
            posts.map((post) => (
              <a href={`/blog/${post.id}`} class="block group no-underline">
                <article class="border-b border-gray-6 pb-10">
                  <h3 class="font-serif text-xl font-bold text-gray-12 group-hover:text-tomato-9 transition-colors duration-200">
                    {post.data.title}
                  </h3>
                  <p class="mt-1 text-sm text-gray-10">
                    {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </p>
                  <p class="mt-2 text-gray-11 leading-relaxed">{post.data.description}</p>
                </article>
              </a>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>
